BACKEND_URL=http://localhost:3002
BACKEND_APP_API_KEY=
# Short invite passphrase. When AUTH_REQUIRE_SIWS=true this can be a
# human-shareable code ("beta") because the wallet signature is the real
# auth factor. When AUTH_REQUIRE_SIWS=false this is the only login secret;
# pick something ≥ 16 chars.
WEB_PASSWORD=
# Sign-In With Solana toggle. When `true`, the /login page requires the
# user to connect a Solana wallet and sign a server-issued nonce; the
# invite passphrase becomes a secondary gate. When unset/`false`, the
# legacy passphrase-only loginAction in app/login/actions.ts is the
# active path (kept for rollback).
AUTH_REQUIRE_SIWS=
# Optional domain override for the SIWS canonical message header. Falls
# back to wallet.victorylabs.app when unset. Must match the user's
# browser bar to satisfy Phantom's domain-binding hint.
SIWS_DOMAIN=

# Same-origin RPC proxy upstream — used by /web-api/rpc to forward a
# tightly scoped JSON-RPC subset (sendTransaction, getSignatureStatuses,
# getBlockHeight, getLatestBlockhash) on the client's behalf. Server-only
# (NO `NEXT_PUBLIC_` prefix) so the URL/key never lands in the client
# bundle. Set to a Helius / Triton URL with API key for production.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
